{
    "name": "kode/di",
    "type": "library",
    "description": "高性能 PHP 8.1+ 依赖注入容器，支持属性注入、生命周期管理、协程上下文隔离，兼容 PSR-11",
    "keywords": ["di", "ioc", "container", "dependency-injection", "psr-11", "attribute", "fiber", "coroutine", "kodephp"],
    "license": "Apache-2.0",
    "version": "1.0.2",
    "authors": [
        {
            "name": "半本正经",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/container": "^1.1 || ^2.0",
        "kode/attributes": "^1.0"
    },
    "suggest": {
        "kode/context": "用于协程/Fiber环境下的上下文隔离支持",
        "kode/facade": "用于门面模式支持"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Kode\\DI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\DI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "check": "phpstan analyse src --level=max",
        "fix": "php-cs-fixer fix src --rules=@PSR12"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
